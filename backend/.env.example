# Copy to `backend/.env` (same folder as this example). The API loads it on startup.
# Do not commit real keys — add `backend/.env` to `.gitignore` if needed.
#
OPENAI_API_KEY=sk-...
# Optional (default gpt-4o-mini):
# OPENAI_SUMMARY_MODEL=gpt-4o-mini
# Optional: comma-separated frontend origins allowed by CORS
# CORS_ORIGINS=http://localhost:3000,https://insurecast.symfa.ai
